# Runtime state (regenerated by app.sh / csv-joiner.sh on each run)
functions/directory.txt
functions/selected_file.txt

# App-generated output and archive — keep folders, ignore contents
output/*
!output/.gitkeep
history/*
!history/.gitkeep

# Test artifacts (regenerated by integration_test.sh / mock_whiptail.sh)
tests/*.log
tests/test_output.txt

# Editor / IDE / OS
.claude/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Backups and scratch
*.bak
*.tmp
*~
